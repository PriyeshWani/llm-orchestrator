{
  "name": "llm-orchestrator",
  "version": "1.0.0",
  "description": "Multi-model LLM orchestrator with DAG-based task decomposition and parallel execution",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
