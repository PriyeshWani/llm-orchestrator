# LLM Orchestrator Environment Variables
# Copy this to .env and fill in your API keys

# ===========================================
# Server Configuration
# ===========================================
PORT=3000
REPO_PATH=/path/to/your/project

# ===========================================
# API Keys (Optional - only needed for cloud providers)
# Leave empty to use local models (Ollama/LM Studio)
# ===========================================

# OpenAI (GPT-4, GPT-3.5)
OPENAI_API_KEY=

# Anthropic (Claude Opus, Sonnet, Haiku)
ANTHROPIC_API_KEY=

# Groq (Free tier available - fast Llama inference)
GROQ_API_KEY=

# Together AI (Free credits available)
TOGETHER_API_KEY=

# ===========================================
# Local Models (No API key needed)
# ===========================================
# Ollama: Install from https://ollama.com
#   ollama pull gemma2:2b
#   ollama serve
#
# LM Studio: Download from https://lmstudio.ai
#   Start local server on port 1234
